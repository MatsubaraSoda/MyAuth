{
  "name": "my-auth-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:drizzle-kit": "npm run dev:drizzle-kit --workspace apps/api",
    "dev": "concurrently -k -n api,web,drizzle \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:drizzle-kit\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
